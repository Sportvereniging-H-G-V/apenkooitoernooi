---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const site = await import('../../content/site.json');
const voorwaarden = await import('../../content/voorwaarden.json');
---
<Base title="Algemene Voorwaarden - Apenkooitoernooi">
  <Header title={site.default.brand} />
  
  <!-- Custom Hero sectie -->
  <section class="relative py-24 sm:py-32 overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 pt-32 sm:pt-40">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-10 left-10 w-64 h-64 bg-primary-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <p class="text-primary-600 font-bold mb-4 tracking-[0.2em] uppercase animate-fade-in">Juridische Informatie</p>
      <h1 class="hero-heading text-slate-900 mb-8 animate-fade-in delay-100">
        {voorwaarden.default.title}
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed max-w-4xl mx-auto mb-4 animate-fade-in delay-200">
        {voorwaarden.default.subtitle}
      </p>
      <p class="text-sm text-slate-500 font-sans uppercase tracking-widest font-bold animate-fade-in delay-300">
        Georganiseerd door {site.default.org}
      </p>
    </div>
  </section>
  
  <!-- Intro sectie -->
  <section class="py-12 sm:py-16 bg-white relative">
    <div class="max-w-4xl mx-auto px-6">
      <div class="bg-primary-50 border-l-8 border-primary-500 p-8 sm:p-10 rounded-r-[2.5rem] shadow-sm mb-6 animate-fade-in">
        <p class="text-lg sm:text-xl text-slate-700 leading-relaxed font-sans font-medium italic">"{voorwaarden.default.intro}"</p>
      </div>
      <p class="text-sm text-slate-400 text-right font-sans font-bold uppercase tracking-widest">{voorwaarden.default.lastUpdated}</p>
    </div>
  </section>
  
  <!-- Voorwaarden secties -->
  <div class="bg-white pb-20">
    {voorwaarden.default.sections.map((section, sectionIndex) => (
      <section class="section-spacing relative overflow-hidden pt-10 sm:pt-16">
        {sectionIndex % 2 === 1 && <div class="absolute inset-0 bg-slate-50 bg-grid-pattern opacity-20 pointer-events-none"></div>}
        <div class="max-w-6xl mx-auto px-6 relative">
          <div class="flex items-center gap-4 mb-12 sm:mb-16 animate-fade-in">
            <div class="w-12 h-12 bg-primary-600 text-white rounded-2xl flex items-center justify-center text-xl font-bold shadow-lg shadow-primary-100">
              {sectionIndex + 1}
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900">{section.title}</h2>
          </div>
          
          <div class="grid md:grid-cols-2 gap-8 sm:gap-10">
            {section.items.map((item, itemIdx) => (
              <div class="glass-card rounded-3xl p-8 hover:shadow-2xl transition-all duration-500 group animate-fade-in border-slate-100" style={`animation-delay: ${itemIdx * 100}ms`}>
                <h3 class="text-xl sm:text-2xl text-slate-900 mb-4 flex items-start group-hover:text-primary-600 transition-colors font-hotMustard tracking-wide">
                  <span class="text-primary-600 mr-4 group-hover:rotate-12 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                  </span>
                  {item.titel}
                </h3>
                <p class="text-slate-600 leading-relaxed text-lg font-sans font-medium">{item.beschrijving}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>
  
  <!-- Contact sectie -->
  <section class="section-spacing bg-slate-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-dot-pattern opacity-10"></div>
    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-6">Vragen over de voorwaarden?</h2>
      <p class="text-lg sm:text-xl text-slate-600 mb-10 max-w-2xl mx-auto font-sans font-medium">
        Heb je vragen over deze algemene voorwaarden? Neem gerust contact met ons op.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Contact opnemen
        </a>
        <a href="/faq" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
          FAQ bekijken
        </a>
      </div>
    </div>
  </section>
  
  <Footer org={site.default.org} contact={site.default.contact} />
</Base>
