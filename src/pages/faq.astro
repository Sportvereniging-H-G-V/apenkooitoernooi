---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const site = await import('../../content/site.json');
const faq = await import('../../content/faq.json');
---
<Base title="Veelgestelde vragen | Apenkooitoernooi">
  <Header title={site.default.brand} />
  
  <!-- Custom Hero sectie -->
  <section class="relative py-24 sm:py-32 overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 pt-32 sm:pt-40">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-10 left-10 w-64 h-64 bg-primary-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <p class="text-primary-600 font-bold mb-4 tracking-[0.2em] uppercase animate-fade-in">Hulp & Informatie</p>
      <h1 class="hero-heading text-slate-900 mb-8 animate-fade-in delay-100 whitespace-pre-line leading-[1.1]">
        {faq.default.title}
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed max-w-4xl mx-auto mb-10 animate-fade-in delay-200">
        {faq.default.subtitle}
      </p>
      <div class="bg-white/50 backdrop-blur-sm rounded-3xl p-6 sm:p-8 max-w-3xl mx-auto border border-white/50 shadow-sm animate-fade-in delay-300">
        <p class="text-lg text-slate-700 leading-relaxed font-sans font-medium italic">
          "{faq.default.intro}"
        </p>
      </div>
    </div>
  </section>
  
  <!-- FAQ secties -->
  <div class="bg-white">
    {faq.default.sections.map((section, sectionIndex) => (
      <section class="section-spacing relative overflow-hidden">
        {sectionIndex % 2 === 1 && <div class="absolute inset-0 bg-slate-50 bg-grid-pattern opacity-20 pointer-events-none"></div>}
        <div class="max-w-6xl mx-auto px-6 relative">
          <div class="flex items-center gap-4 mb-12 sm:mb-16 animate-fade-in">
            <div class="w-12 h-12 bg-primary-600 rounded-2xl flex items-center justify-center shadow-lg shadow-primary-100">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900">{section.title}</h2>
          </div>
          
          <div class="grid md:grid-cols-2 gap-8 sm:gap-10">
            {section.faqs.map((faqItem, faqIndex) => (
              <div class="glass-card rounded-3xl p-8 hover:shadow-2xl transition-all duration-500 group animate-fade-in border-slate-100" style={`animation-delay: ${faqIndex * 100}ms`}>
                <h3 class="text-xl sm:text-2xl text-slate-900 mb-4 flex items-start group-hover:text-primary-600 transition-colors">
                  <span class="text-primary-600 mr-4 font-bold font-condensed text-2xl group-hover:scale-125 transition-transform group-hover:rotate-12">Q.</span>
                  <span class="font-bold">{faqItem.q}</span>
                </h3>
                <div class="flex items-start">
                  <span class="text-slate-300 mr-4 font-bold font-condensed text-2xl">A.</span>
                  <p class="text-slate-600 leading-relaxed text-lg font-sans font-medium">{faqItem.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>
  
  <!-- Contact sectie -->
  <section class="section-spacing bg-slate-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-dot-pattern opacity-10"></div>
    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <h2 class="text-3xl sm:text-4xl md:text-5xl mb-6 font-condensed font-bold uppercase">Nog vragen?</h2>
      <p class="text-lg sm:text-xl text-slate-400 mb-10 max-w-2xl mx-auto">
        Staat jouw vraag er niet bij? Neem gerust contact met ons op via het contactformulier.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Contact opnemen
        </a>
        <a href="/spelregels" class="btn-secondary !bg-slate-800 !text-white hover:!bg-slate-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          Spelregels bekijken
        </a>
      </div>
    </div>
  </section>
  
  <Footer org={site.default.org} contact={site.default.contact} />
</Base>
