---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const site = await import('../../content/site.json');
const spelregels = await import('../../content/spelregels.json');
---
<Base title="Spelregels Apenkooitoernooi - Alle regels en afspraken">
  <Header title={site.default.brand} />
  
  <!-- Custom Hero sectie -->
  <section class="relative py-24 sm:py-32 overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 pt-32 sm:pt-40">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-10 left-10 w-64 h-64 bg-primary-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <p class="text-primary-600 font-bold mb-4 tracking-[0.2em] uppercase animate-fade-in">Fair Play & Plezier</p>
      <h1 class="hero-heading text-slate-900 mb-8 animate-fade-in delay-100">
        {spelregels.default.title}
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed max-w-4xl mx-auto mb-10 animate-fade-in delay-200">
        {spelregels.default.subtitle}
      </p>
      <div class="bg-white/50 backdrop-blur-sm rounded-3xl p-6 sm:p-8 max-w-3xl mx-auto border border-white/50 shadow-sm animate-fade-in delay-300">
        <p class="text-lg text-slate-700 leading-relaxed mb-4 italic font-medium font-sans">
          "{spelregels.default.intro}"
        </p>
        <p class="text-sm text-slate-500 font-sans uppercase tracking-widest font-bold">
          Georganiseerd door {site.default.org}
        </p>
      </div>
    </div>
  </section>
  
  <!-- Spelregels secties -->
  <section class="section-spacing bg-white relative">
    <div class="max-w-6xl mx-auto px-6">
      <div class="space-y-16 sm:space-y-24">
        {spelregels.default.sections.map((section, sectionIdx) => (
          <div class="animate-fade-in" style={`animation-delay: ${sectionIdx * 100}ms`}>
            <div class="flex items-center gap-4 mb-8 sm:mb-12">
              <span class="bg-primary-600 text-white w-12 h-12 rounded-2xl flex items-center justify-center text-xl font-bold shadow-lg shadow-primary-200">0{sectionIdx + 1}</span>
              <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 leading-none">{section.title}</h2>
            </div>
            
            <div class="grid md:grid-cols-2 gap-6 sm:gap-8">
              {section.items.map((item, itemIdx) => (
                <div class="glass-card rounded-3xl p-6 sm:p-8 hover:shadow-2xl transition-all duration-500 border-slate-100 hover:border-primary-100 group">
                  <h3 class="text-xl sm:text-2xl text-slate-900 mb-4 flex items-center font-condensed font-bold tracking-wide group-hover:text-primary-600 transition-colors uppercase">
                    <span class="text-primary-600 mr-3 group-hover:rotate-12 transition-transform">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </span>
                    {item.titel}
                  </h3>
                  <p class="text-slate-600 leading-relaxed text-base font-sans font-medium">{item.beschrijving}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Contact sectie -->
  <section class="section-spacing bg-slate-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-dot-pattern opacity-10"></div>
    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-6">Vragen over de spelregels?</h2>
      <p class="text-lg sm:text-xl text-slate-600 mb-10 max-w-2xl mx-auto font-medium">
        Heb je vragen over de spelregels of het toernooi? Neem gerust contact met ons op.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Contact opnemen
        </a>
        <a href="/faq" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
          Bekijk FAQ
        </a>
      </div>
    </div>
  </section>
  
  <Footer org={site.default.org} contact={site.default.contact} />
</Base>
