---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const site = await import('../../content/site.json');
const contact = await import('../../content/contact.json');

// Haal Turnstile site key op aan server-side
const runtimeEnv = (Astro.locals as any)?.runtime?.env;
const turnstileSiteKey = runtimeEnv?.PUBLIC_TURNSTILE_SITE_KEY ||
                         import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
---
<Base title="Contact - Apenkooitoernooi">
  <Header title={site.default.brand} />
  
  <!-- Custom Hero sectie -->
  <section class="relative py-24 sm:py-32 overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 pt-32 sm:pt-40">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-10 left-10 w-64 h-64 bg-primary-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <p class="text-primary-600 font-bold mb-4 tracking-[0.2em] uppercase animate-fade-in">Stuur een bericht</p>
      <h1 class="hero-heading text-slate-900 mb-8 animate-fade-in delay-100">
        {contact.default.title}
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed max-w-4xl mx-auto mb-4 animate-fade-in delay-200">
        {contact.default.subtitle}
      </p>
      <p class="text-sm text-slate-500 font-sans uppercase tracking-widest font-bold animate-fade-in delay-300">
        Georganiseerd door {site.default.org}
      </p>
    </div>
  </section>
  
  <!-- Contactgegevens en formulier -->
  <section class="section-spacing bg-white relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Contactgegevens (links) -->
        <div class="flex flex-col space-y-8 animate-fade-in">
          <div class="glass-card rounded-3xl p-8 hover:shadow-2xl transition-all duration-500 border-slate-100 group">
            <div class="w-16 h-16 bg-primary-100 text-primary-600 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <h3 class="text-2xl text-slate-900 mb-2">E-mail</h3>
            <p class="text-slate-500 mb-4 font-sans font-medium italic">Vragen over inschrijvingen of algemene informatie</p>
            <a href={`mailto:${contact.default.contact.email}`} class="text-xl sm:text-2xl text-primary-600 hover:text-primary-700 font-bold break-words transition-colors">
              {contact.default.contact.email}
            </a>
          </div>
          
          <div class="glass-card rounded-3xl p-8 hover:shadow-2xl transition-all duration-500 border-slate-100 group">
            <div class="w-16 h-16 bg-green-100 text-green-600 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h3 class="text-2xl text-slate-900 mb-2">Telefoon</h3>
            <p class="text-slate-500 mb-4 font-sans font-medium italic">Direct contact voor dringende zaken</p>
            <a href={`tel:${contact.default.contact.phone.replace(/\s/g, '')}`} class="text-xl sm:text-2xl text-primary-600 hover:text-primary-700 font-bold break-words transition-colors">
              {contact.default.contact.phone}
            </a>
          </div>
          
          {/* Social Media */}
          {(contact.default.contact.social?.facebook || contact.default.contact.social?.instagram) && (
            <div class="glass-card rounded-3xl p-8 border-slate-100 bg-slate-50">
              <h3 class="text-xl font-bold text-slate-900 mb-6 text-center">Volg de actie</h3>
              <div class="grid grid-cols-3 gap-4">
                {contact.default.contact.social?.facebook && contact.default.contact.social.facebook.map((fb, idx) => (
                  <a href={fb} target="_blank" rel="noopener noreferrer" 
                     class="group flex flex-col items-center p-4 bg-white rounded-2xl hover:bg-primary-50 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 border border-slate-100">
                    <div class="mb-3 text-blue-600 group-hover:scale-110 transition-transform duration-300">
                      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    </div>
                    <span class="text-xs font-bold text-slate-900 text-center">{idx === 0 ? 'Apenkooi' : 'HGV'}</span>
                  </a>
                ))}
                
                {contact.default.contact.social?.instagram && (
                  <a href={contact.default.contact.social.instagram} target="_blank" rel="noopener noreferrer" 
                     class="group flex flex-col items-center p-4 bg-white rounded-2xl hover:bg-pink-50 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 border border-slate-100">
                    <div class="mb-3 text-pink-600 group-hover:scale-110 transition-transform duration-300">
                      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </div>
                    <span class="text-xs font-bold text-slate-900 text-center">Instagram</span>
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
        
        <!-- Contactformulier (rechts) -->
        <div class="animate-fade-in delay-200">
          <form method="post" action="/api/submit" class="glass-card p-6 sm:p-10 rounded-[2rem] shadow-2xl border-primary-100 flex flex-col gap-6 relative">
            <div class="absolute -top-6 -right-6 w-12 h-12 bg-accent-500 text-white rounded-2xl flex items-center justify-center rotate-12 shadow-lg z-10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </div>
            
            <input type="hidden" name="formId" value="contact" />
            
            <div class="mb-2">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Stuur een bericht</h3>
              <p class="text-slate-500 font-sans font-medium">We reageren meestal binnen 24 uur.</p>
            </div>
            
            <div class="space-y-4">
              <div>
                <label for="naam" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Naam *</label>
                <input id="naam" name="naam" type="text" placeholder="Je volledige naam" required minlength="2" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" />
              </div>
              
              <div>
                <label for="email" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">E-mailadres *</label>
                <input id="email" name="email" type="email" placeholder="jouw@email.nl" required class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" />
              </div>
              
              <div>
                <label for="bericht" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Bericht *</label>
                <textarea id="bericht" name="bericht" placeholder="Typ hier je vraag of opmerking..." required minlength="10" rows="5" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none resize-none font-sans font-medium"></textarea>
              </div>
            </div>
            
            <div class="bg-amber-50 border border-amber-100 rounded-2xl p-5">
              <label class="flex items-start gap-4 cursor-pointer group">
                <input type="checkbox" name="agree" value="true" required class="mt-1 w-5 h-5 text-primary-600 border-slate-300 rounded-lg focus:ring-primary-500 focus:ring-2 cursor-pointer transition-transform group-hover:scale-110" />
                <span class="text-sm text-amber-900 font-sans font-medium leading-relaxed">
                  Ik ga akkoord met de <a href="/voorwaarden" class="underline decoration-amber-300 decoration-2 underline-offset-2 hover:decoration-amber-500 transition-all font-bold" target="_blank">algemene voorwaarden</a> en geef toestemming voor verwerking.
                </span>
              </label>
            </div>
            
            <input type="text" name="company" class="hidden" tabindex="-1" autocomplete="off" />
            
            <div id="turnstile-container" class="flex justify-center min-h-[65px]" data-sitekey={turnstileSiteKey}></div>
            <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
            
            <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-2xl p-5 text-red-800 text-sm font-sans font-medium animate-fade-in"></div>
            
            <button type="submit" id="submit-btn" class="btn-primary w-full !rounded-2xl group">
              <span class="group-hover:translate-x-1 transition-transform flex items-center justify-center">
                Verstuur bericht
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12h14m-7-7 7 7-7 7"/></svg>
              </span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
  
  <script>
    // Laad Turnstile widget dynamisch via API endpoint
    (function() {
      let widgetLoaded = false;
      let widgetId = null;
      
      document.addEventListener('DOMContentLoaded', async () => {
        if (widgetLoaded) return;
        
        const form = document.querySelector('form[action="/api/submit"]');
        const errorDiv = document.getElementById('form-error');
        const submitBtn = document.getElementById('submit-btn');
        const container = document.getElementById('turnstile-container');
        
        if (!form || !container) return;
        
        // Probeer site key uit data-attribute (server-side gerenderd), fallback naar API
        try {
          let siteKey = container.dataset.sitekey || '';
          if (!siteKey) {
            const response = await fetch('/api/turnstile-key');
            const data = await response.json();
            siteKey = data.siteKey || '';
          }

          if (siteKey && siteKey.length > 0) {
            // Wacht tot Turnstile script geladen is (max 3 seconden)
            if (typeof (window as any).turnstile === 'undefined') {
              await new Promise<void>((resolve, reject) => {
                let attempts = 0;
                const checkInterval = setInterval(() => {
                  attempts++;
                  if (typeof (window as any).turnstile !== 'undefined') {
                    clearInterval(checkInterval);
                    resolve();
                  } else if (attempts >= 30) {
                    clearInterval(checkInterval);
                    reject(new Error('Turnstile script niet geladen na 3 seconden'));
                  }
                }, 100);
              });
            }

            // Render Turnstile widget
            if (typeof (window as any).turnstile !== 'undefined' && !widgetLoaded && container.children.length === 0) {
              widgetLoaded = true;
              const widgetDiv = document.createElement('div');
              widgetDiv.id = 'turnstile-widget';
              container.appendChild(widgetDiv);

              try {
                const currentHost = window.location.hostname;
                widgetId = (window as any).turnstile.render(widgetDiv, {
                  sitekey: siteKey,
                  theme: 'light',
                  callback: function(token: string) { /* token ready */ },
                  'error-callback': function(error: any) {
                    container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium"><p class="font-bold mb-1">⚠️ Domein niet toegestaan</p><p>Het domein <code class="bg-red-100 px-1 rounded">' + currentHost + '</code> is niet toegevoegd aan de Turnstile-domeinen.</p></div>';
                  },
                  'expired-callback': function() {
                    if (widgetId !== null && (window as any).turnstile) {
                      try { (window as any).turnstile.reset(widgetId); } catch(e) {}
                    }
                  }
                });
              } catch (renderError: any) {
                container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium">⚠️ Captcha kon niet worden geladen.</div>';
              }
            }
          } else {
            container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium">⚠️ Captcha niet beschikbaar: PUBLIC_TURNSTILE_SITE_KEY niet ingesteld.</div>';
          }
        } catch (err) {
          container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium">⚠️ Captcha kon niet worden geladen.</div>';
        }
        
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (!errorDiv || !submitBtn) return;

          errorDiv.classList.add('hidden');
          errorDiv.textContent = '';
          
          const turnstileInput = form.querySelector('input[name="cf-turnstile-response"]') as HTMLInputElement;
          if (!turnstileInput?.value) {
            errorDiv.textContent = 'Captcha is verplicht.';
            errorDiv.classList.remove('hidden');
            return;
          }
          
          submitBtn.disabled = true;
          const originalText = submitBtn.innerHTML;
          submitBtn.innerHTML = '<span class="flex items-center justify-center"><svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Verzenden...</span>';
          
          try {
            const formData = new FormData(form as HTMLFormElement);
            const response = await fetch('/api/submit', {
              method: 'POST',
              body: formData
            });
            
            const result = await response.json();
            
            if (response.ok && result.success) {
              errorDiv.classList.remove('hidden', 'bg-red-50', 'text-red-800');
              errorDiv.classList.add('bg-green-50', 'text-green-800', 'border-green-100');
              errorDiv.textContent = result.message || 'Bericht verzonden!';
              (form as HTMLFormElement).reset();
              if (widgetId !== null && (window as any).turnstile) (window as any).turnstile.reset(widgetId);
            } else {
              errorDiv.textContent = result.error || 'Er ging iets mis.';
              errorDiv.classList.remove('hidden');
            }
          } catch (err) {
            errorDiv.textContent = 'Netwerkfout. Probeer het opnieuw.';
            errorDiv.classList.remove('hidden');
          } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
          }
        });
      });
    })();
  </script>
  
  <!-- FAQ CTA -->
  <section class="section-spacing bg-slate-50 relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative">
      <h2 class="text-3xl sm:text-4xl text-slate-900 mb-6">Nog meer informatie?</h2>
      <p class="text-lg text-slate-600 mb-10 max-w-2xl mx-auto font-medium font-sans">
        Kijk ook eens bij onze veelgestelde vragen of bekijk de spelregels.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/faq" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          FAQ bekijken
        </a>
        <a href="/spelregels" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          Spelregels bekijken
        </a>
      </div>
    </div>
  </section>
  
  <Footer org={site.default.org} contact={site.default.contact} />
</Base>
