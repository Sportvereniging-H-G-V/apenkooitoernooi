---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { pickVariant } from '../lib/abVariant';

const site = await import('../../content/site.json');
const { v, setCookie } = pickVariant(Astro.request.headers.get('cookie') || '');
Astro.response.headers.set('Set-Cookie', setCookie);

const emailError = Astro.url.searchParams.get('email_error') === 'true';
---
<Base title="Bedankt - Apenkooitoernooi">
  <Header title={site.default.brand} />
  
  <!-- Custom Hero sectie -->
  <section class="relative py-24 sm:py-32 overflow-hidden bg-gradient-to-br from-green-50 via-white to-primary-50 pt-32 sm:pt-40">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-10 left-10 w-64 h-64 bg-green-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-primary-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 text-green-600 rounded-3xl mb-8 shadow-lg shadow-green-100 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h1 class="hero-heading text-slate-900 mb-8 animate-fade-in delay-100">
        Bedankt voor je aanmelding!
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto mb-12 animate-fade-in delay-200 font-sans font-medium">
        We hebben je inzending in goede orde ontvangen. {emailError ? 'Let op: Er was een probleem met het versturen van de bevestigingsmail, maar je aanmelding is wel bij ons binnengekomen.' : 'Je ontvangt binnen enkele minuten een e-mailbevestiging op het opgegeven adres.'}
      </p>
      
      {emailError && (
        <div class="max-w-2xl mx-auto mt-8 p-6 bg-amber-50 border border-amber-200 rounded-3xl shadow-sm animate-fade-in delay-300">
          <div class="flex items-start gap-4 text-left">
            <div class="bg-amber-100 p-2 rounded-xl text-amber-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-amber-900 mb-1">Bevestigingsmail niet verzonden</h3>
              <p class="text-amber-800 font-sans font-medium">
                Maak je geen zorgen: je aanmelding is succesvol opgeslagen in ons systeem. Door een technisch probleem kon de automatische mail niet direct verzonden worden. 
              </p>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>
  
  <!-- Wat gebeurt er nu? -->
  <section class="section-spacing bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16 animate-fade-in">
        <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-4">Wat gebeurt er nu?</h2>
        <p class="text-lg text-slate-500 font-sans font-medium">Het proces na je inschrijving</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Connecting line -->
        <div class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 bg-slate-100 -translate-y-1/2 z-0"></div>
        
        <div class="glass-card rounded-[2rem] p-8 text-center relative z-10 animate-fade-in border-slate-50 shadow-xl" style="animation-delay: 100ms">
          <div class="w-16 h-16 bg-green-100 text-green-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-sm group-hover:rotate-6 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Bevestiging</h3>
          <p class="text-slate-600 font-sans font-medium">Je ontvangt direct een automatische bevestiging van je deelname.</p>
        </div>
        
        <div class="glass-card rounded-[2rem] p-8 text-center relative z-10 animate-fade-in border-slate-50 shadow-xl" style="animation-delay: 200ms">
          <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-sm group-hover:rotate-6 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.7a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Verwerking</h3>
          <p class="text-slate-600 font-sans font-medium">Onze organisatie verwerkt de gegevens en deelt de poule-indeling.</p>
        </div>
        
        <div class="glass-card rounded-[2rem] p-8 text-center relative z-10 animate-fade-in border-slate-50 shadow-xl" style="animation-delay: 300ms">
          <div class="w-16 h-16 bg-primary-100 text-primary-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-sm group-hover:rotate-6 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Informatie</h3>
          <p class="text-slate-600 font-sans font-medium">Kort voor het toernooi ontvang je het definitieve schema en de tijden.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Acties -->
  <section class="section-spacing bg-slate-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-dot-pattern opacity-10"></div>
    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-6">Wat wil je nu doen?</h2>
      <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto font-sans font-medium">
        Bereid je voor op het toernooi door de spelregels door te nemen of ga terug naar de startpagina.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Terug naar home
        </a>
        <a href="/spelregels" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          Spelregels bekijken
        </a>
      </div>
    </div>
  </section>
  
  <Footer org={site.default.org} contact={site.default.contact} />
</Base>
