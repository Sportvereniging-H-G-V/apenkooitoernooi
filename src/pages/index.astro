---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import FAQ from '../components/FAQ.astro';
import Turnstile from '../components/Turnstile.astro';
import InschrijfModal from '../components/InschrijfModal.astro';
import { pickVariant } from '../lib/abVariant';

const site = await import('../../content/site.json');
const home = await import('../../content/home.json');
const { v, setCookie } = pickVariant(Astro.request.headers.get('cookie') || '');
Astro.response.headers.set('Set-Cookie', setCookie);
---
<Base title="Apenkooitoernooi voor basisscholen — inschrijvingen, spelregels & informatie">
  <Header title={site.default.brand} />
  
  <Hero 
    eyebrow={home.default.hero.eyebrow}
    title={home.default.hero.title}
    subtitle={home.default.hero.subtitle}
    lead={home.default.hero.lead}
    backgroundImage={home.default.hero.heroImage}
    ctas={home.default.hero.ctas}
  />
  
  <!-- Wat is het Apenkooitoernooi? -->
  <section class="section-spacing bg-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-primary-50 rounded-full blur-3xl -mr-32 -mt-32"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-in">
          <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-6 leading-tight">{home.default.whatIs.title}</h2>
          <p class="text-lg sm:text-xl text-slate-600 leading-relaxed">{home.default.whatIs.body}</p>
        </div>
        <div class="relative animate-fade-in delay-200">
          <div class="absolute inset-0 bg-primary-600 rounded-3xl rotate-3 scale-105 opacity-10"></div>
          <div class="bg-slate-100 rounded-3xl p-4 sm:p-6 text-center overflow-hidden relative shadow-2xl">
            <div class="w-full h-64 sm:h-80 rounded-2xl overflow-hidden shadow-inner">
              <img 
                src="/images/homepage/zaal-overzicht-800w.avif" 
                srcset="/images/homepage/zaal-overzicht-400w.avif 400w, /images/homepage/zaal-overzicht-800w.avif 800w, /images/homepage/zaal-overzicht-1200w.avif 1200w"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 800px"
                alt="Overzichtsbeeld van zaal met apenkooi toestellen"
                class="w-full h-full object-cover rounded-2xl hover:scale-110 transition-transform duration-700"
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Voor wie organiseren we dit? -->
  <section class="section-spacing bg-slate-50 bg-grid-pattern">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 animate-fade-in">
        <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-4">{home.default.forWho.title}</h2>
        <p class="text-lg sm:text-xl text-slate-600 max-w-2xl mx-auto">{home.default.forWho.subtitle}</p>
      </div>
      
      <div class="grid sm:grid-cols-2 gap-8">
        {home.default.forWho.tournaments.map((tournament, index) => (
          <div class="glass-card rounded-3xl p-6 sm:p-8 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group animate-fade-in" style={`animation-delay: ${index * 150}ms`}>
            <div class="mb-8 overflow-hidden rounded-2xl">
              <div class="w-full h-56 sm:h-72 overflow-hidden">
                <img 
                  src={index === 0 ? "/images/homepage/leeftijdsgroep-4-6-800w.avif" : "/images/homepage/leeftijdsgroep-6-8-800w.avif"}
                  srcset={index === 0 ? "/images/homepage/leeftijdsgroep-4-6-400w.avif 400w, /images/homepage/leeftijdsgroep-4-6-800w.avif 800w, /images/homepage/leeftijdsgroep-4-6-1200w.avif 1200w" : "/images/homepage/leeftijdsgroep-6-8-400w.avif 400w, /images/homepage/leeftijdsgroep-6-8-800w.avif 800w, /images/homepage/leeftijdsgroep-6-8-1200w.avif 1200w"}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 800px"
                  alt={index === 0 ? "Groep 4-6 kinderen in actie" : "Groep 6-8 kinderen in actie"}
                  class="w-full h-full object-cover object-center group-hover:scale-110 transition-transform duration-700"
                  width="800"
                  height="600"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
            <h3 class="text-2xl sm:text-3xl text-slate-900 mb-4">{tournament.title}</h3>
            <p class="text-slate-600 mb-8 leading-relaxed">{tournament.description}</p>
            {tournament.features && tournament.features.length > 0 && (
              <ul class="space-y-4">
                {tournament.features.map((feature) => (
                  <li class="flex items-start group/item">
                    <span class="bg-green-100 text-green-600 rounded-full p-1 mr-4 mt-0.5 flex-shrink-0 group-hover/item:bg-green-200 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    </span>
                    <span class="text-slate-700 font-medium">{feature}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Hoe werkt inschrijven? -->
  <section class="section-spacing bg-white relative">
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent-50 rounded-full blur-3xl -ml-48 -mb-48 opacity-60"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative order-2 lg:order-1 animate-fade-in">
          <div class="absolute -inset-4 bg-accent-500 rounded-3xl -rotate-2 scale-105 opacity-10"></div>
          <div class="bg-slate-100 rounded-3xl p-4 sm:p-6 text-center overflow-hidden relative shadow-xl">
            <div class="w-full h-64 sm:h-96 rounded-2xl overflow-hidden">
              <img 
                src="/images/homepage/inschrijving-formulier-800w.avif" 
                srcset="/images/homepage/inschrijving-formulier-400w.avif 400w, /images/homepage/inschrijving-formulier-800w.avif 800w, /images/homepage/inschrijving-formulier-1200w.avif 1200w"
                sizes="(max-width: 1024px) 100vw, 50vw"
                alt="Formulier/checklist voor inschrijving"
                class="w-full h-full object-cover object-center rounded-2xl hover:rotate-1 transition-transform duration-700"
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2 animate-fade-in delay-200">
          <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-8">{home.default.howToRegister.title}</h2>
          <ol class="space-y-6 mb-10">
            {home.default.howToRegister.steps.map((step, index) => (
              <li class="flex items-start group">
                <span class="bg-primary-600 text-white rounded-2xl w-10 h-10 flex items-center justify-center text-lg font-bold mr-5 flex-shrink-0 shadow-lg group-hover:scale-110 group-hover:rotate-6 transition-transform">{index + 1}</span>
                <span class="text-lg text-slate-700 leading-relaxed font-medium pt-1">{step}</span>
              </li>
            ))}
          </ol>
          <button 
            type="button"
            onclick="if (typeof window.openInschrijfModal === 'function') { window.openInschrijfModal('team'); }"
            class="btn-primary w-full sm:w-auto"
          >
            {home.default.howToRegister.cta.label}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Veilig & eerlijk spelen -->
  <section class="section-spacing bg-gradient-to-br from-green-50 to-blue-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-dot-pattern text-slate-200 opacity-50"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-in">
          <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-6">{home.default.safety.title}</h2>
          <p class="text-lg sm:text-xl text-slate-600 leading-relaxed mb-10">{home.default.safety.body}</p>
          <a href={home.default.safety.cta.href} class="btn-primary bg-green-600 hover:bg-green-700 shadow-green-200">
            {home.default.safety.cta.label}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
          </a>
        </div>
        <div class="animate-fade-in delay-200">
          <div class="bg-white rounded-3xl p-3 shadow-2xl">
            <img 
              src="/images/homepage/leerkracht-toezicht-800w.avif" 
              srcset="/images/homepage/leerkracht-toezicht-400w.avif 400w, /images/homepage/leerkracht-toezicht-800w.avif 800w, /images/homepage/leerkracht-toezicht-1200w.avif 1200w"
              sizes="(max-width: 1024px) 100vw, 50vw"
              alt="Leerkracht/scheidsrechter houdt toezicht"
              class="w-full aspect-[16/11] object-cover object-[50%_30%] rounded-2xl shadow-inner"
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Veelgestelde vragen -->
  <section class="section-spacing bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-fade-in">
        <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-4">{home.default.faq.title}</h2>
      </div>
      
      <div class="space-y-6 mb-12 animate-fade-in delay-200">
        {home.default.faq.questions.map((qa) => (
          <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6 sm:p-8 hover:bg-white hover:shadow-xl transition-all duration-300">
            <h3 class="font-bold text-xl text-slate-900 mb-3">{qa.question}</h3>
            <div class="flex items-start">
              <span class="text-primary-600 font-bold mr-3 mt-0.5">→</span>
              <p class="text-lg text-slate-600 leading-relaxed font-sans">{qa.answer}</p>
            </div>
          </div>
        ))}
      </div>
      
      <div class="text-center animate-fade-in delay-300">
        <a href={home.default.faq.cta.href} class="btn-secondary">
          {home.default.faq.cta.label}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Contact & updates -->
  <section class="section-spacing bg-slate-50 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-full h-full bg-grid-pattern opacity-10 pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center relative">
      <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-6 animate-fade-in">{home.default.contact.title}</h2>
      <p class="text-lg sm:text-xl text-slate-600 mb-12 max-w-2xl mx-auto animate-fade-in delay-100">{home.default.contact.body}</p>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12 animate-fade-in delay-200">
        <!-- Apenkooitoernooi Facebook -->
        <a href="https://www.facebook.com/apenkooitoernooi" target="_blank" rel="noopener noreferrer" 
           class="group glass-card p-6 sm:p-8 rounded-3xl hover:-translate-y-2 transition-all duration-500">
          <div class="mb-4 text-blue-600 group-hover:scale-125 transition-transform duration-500">
            <svg class="w-12 h-12 mx-auto" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg text-slate-900 mb-1">Facebook</h3>
          <p class="text-sm text-slate-500 font-sans">Apenkooitoernooi</p>
        </a>
        
        <!-- HGV Facebook -->
        <a href="https://www.facebook.com/HGVHengelo/" target="_blank" rel="noopener noreferrer" 
           class="group glass-card p-6 sm:p-8 rounded-3xl hover:-translate-y-2 transition-all duration-500">
          <div class="mb-4 text-blue-600 group-hover:scale-125 transition-transform duration-500">
            <svg class="w-12 h-12 mx-auto" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg text-slate-900 mb-1">Facebook</h3>
          <p class="text-sm text-slate-500 font-sans">HGV Hengelo</p>
        </a>
        
        <!-- Instagram -->
        <a href="https://www.instagram.com/sportvereniginghgv/" target="_blank" rel="noopener noreferrer" 
           class="group glass-card p-6 sm:p-8 rounded-3xl hover:-translate-y-2 transition-all duration-500">
          <div class="mb-4 text-pink-600 group-hover:scale-125 transition-transform duration-500">
            <svg class="w-12 h-12 mx-auto" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg text-slate-900 mb-1">Instagram</h3>
          <p class="text-sm text-slate-500 font-sans">Sportvereniging HGV</p>
        </a>
        
        <!-- Website -->
        <a href="https://hgvhengelo.nl/" target="_blank" rel="noopener noreferrer" 
           class="group glass-card p-6 sm:p-8 rounded-3xl hover:-translate-y-2 transition-all duration-500">
          <div class="mb-4 group-hover:scale-125 transition-transform duration-500">
            <img src="/images/logo/hgv-logo.avif" alt="HGV Hengelo Logo" class="w-12 h-12 mx-auto object-contain" width="100" height="100" loading="lazy" decoding="async" />
          </div>
          <h3 class="font-bold text-lg text-slate-900 mb-1">Website</h3>
          <p class="text-sm text-slate-500 font-sans">HGV Hengelo</p>
        </a>
      </div>
      
      <div class="animate-fade-in delay-300">
        <p class="text-lg text-slate-600 mb-8 font-medium">Volg ons voor nieuwe speeldagen, foto's, uitslagen en inschrijfopeningen.</p>
        <a href="/contact" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Contact opnemen
        </a>
      </div>
    </div>
  </section>
  
  <!-- Inschrijven CTA sectie -->
  <section id="inschrijven" class="section-spacing bg-white relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-6 animate-fade-in">Klaar om in te schrijven?</h2>
      <p class="text-lg sm:text-xl text-slate-600 mb-12 max-w-2xl mx-auto animate-fade-in delay-100">
        Schrijf je team in voor het apenkooitoernooi. Beleef een onvergetelijke dag vol plezier en sportiviteit!
      </p>
      
      <div class="max-w-4xl mx-auto mb-12 animate-fade-in delay-200">
        <div class="bg-gradient-to-br from-primary-600 to-accent-600 rounded-3xl p-1 shadow-2xl">
          <div class="bg-white rounded-[1.4rem] p-6 sm:p-10 text-left">
            <div class="grid md:grid-cols-2 gap-10 items-center">
              <div>
                <h3 class="text-2xl sm:text-3xl text-slate-900 mb-4">🏆 School Sporttoernooi</h3>
                <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                  Voor basisschoolleerlingen van groep 1-4 en groep 5-8. Teams van 6-8 spelers strijden om de titel!
                </p>
                <ul class="space-y-4">
                  <li class="flex items-center text-slate-700 font-medium">
                    <span class="bg-primary-100 text-primary-600 rounded-full p-1 mr-3">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    </span>
                    Veilig en begeleid
                  </li>
                  <li class="flex items-center text-slate-700 font-medium">
                    <span class="bg-primary-100 text-primary-600 rounded-full p-1 mr-3">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    </span>
                    Duidelijke spelregels
                  </li>
                  <li class="flex items-center text-slate-700 font-medium">
                    <span class="bg-primary-100 text-primary-600 rounded-full p-1 mr-3">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    </span>
                    Prijzen voor winnaars
                  </li>
                </ul>
              </div>
              <div class="relative">
                <div class="absolute inset-0 bg-primary-600 rounded-2xl rotate-3 opacity-10"></div>
                <img 
                  src="/images/school-toernooi/kinderen-actie-toernooi-800w.avif" 
                  srcset="/images/school-toernooi/kinderen-actie-toernooi-400w.avif 400w, /images/school-toernooi/kinderen-actie-toernooi-800w.avif 800w, /images/school-toernooi/kinderen-actie-toernooi-1200w.avif 1200w"
                  sizes="(max-width: 768px) 100vw, 50vw"
                  alt="Kinderen in actie tijdens het apenkooitoernooi"
                  class="w-full aspect-[4/3] object-cover object-[center_18%] rounded-2xl shadow-lg relative z-10"
                  width="800"
                  height="600"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in delay-300">
        <button 
          type="button"
          id="open-inschrijf-modal-btn"
          class="btn-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4-4-4"/><path d="M3 3.41 12 12.41 21 3.41"/></svg>
          Nu inschrijven
        </button>
        <a href="/spelregels" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          Spelregels bekijken
        </a>
      </div>
    </div>
  </section>
  
  <!-- Inschrijf Modal -->
  <InschrijfModal />
  
  <script>
    // Open modal wanneer op "Nu inschrijven" button wordt geklikt
    document.addEventListener('DOMContentLoaded', () => {
      const openBtn = document.getElementById('open-inschrijf-modal-btn');
      if (openBtn && typeof window.openInschrijfModal === 'function') {
        openBtn.addEventListener('click', () => {
          window.openInschrijfModal('team');
        });
      }
    });
  </script>
  
  <Footer org={site.default.org} contact={site.default.contact} />
</Base>
