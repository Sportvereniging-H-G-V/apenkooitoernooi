---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const site = await import('../../content/site.json');
---
<Base title="404 - Pagina niet gevonden - Apenkooitoernooi">
  <Header title={site.default.brand} />
  
  <!-- 404 Hero sectie -->
  <section class="relative py-24 sm:py-32 md:py-40 overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 pt-32 sm:pt-40">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-10 left-10 w-64 h-64 bg-primary-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-200/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <!-- Fun monkey icon -->
      <div class="inline-flex items-center justify-center w-24 h-24 bg-primary-100 text-primary-600 rounded-[2rem] mb-8 shadow-xl shadow-primary-100 rotate-12 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20a10 10 0 1 0 0-20 10 10 0 0 0 0 20Z"/><path d="M12 12a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M12 16v.01"/><path d="M16 12a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M16 16v.01"/><path d="M8 12a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M8 16v.01"/></svg>
      </div>
      
      <!-- 404 nummer -->
      <h1 class="text-9xl sm:text-[12rem] md:text-[15rem] font-bold text-primary-600/10 mb-[-4rem] sm:mb-[-6rem] leading-none select-none font-condensed animate-pulse">
        404
      </h1>
      
      <!-- Titel -->
      <h2 class="text-4xl sm:text-5xl md:text-6xl text-slate-900 mb-8 animate-fade-in">
        Pagina niet gevonden!
      </h2>
      
      <!-- Beschrijving -->
      <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto mb-12 animate-fade-in delay-100 font-sans font-medium">
        Oeps! Deze pagina is wegge-<span class="text-primary-600 font-bold underline decoration-primary-200 underline-offset-4">slingerd</span> of over de toestellen geklommen. 
        We hebben deze link niet kunnen vinden tijdens het <span class="text-primary-600 font-bold">apenkooi</span> spelen!
      </p>
      
      <!-- Actie buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in delay-200">
        <a href="/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Terug naar home
        </a>
        <a href="/#inschrijven" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Nu inschrijven
        </a>
      </div>
    </div>
  </section>
  
  <!-- Help sectie -->
  <section class="section-spacing bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16 animate-fade-in">
        <h2 class="text-3xl sm:text-4xl md:text-5xl text-slate-900 mb-4">Wat zoek je precies?</h2>
        <p class="text-lg text-slate-500 font-sans font-medium">Misschien helpt een van deze links je op weg</p>
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/#inschrijven" class="glass-card rounded-[2rem] p-8 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group border-slate-50">
          <div class="w-12 h-12 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <h4 class="text-xl font-bold text-slate-900 mb-2 font-condensed tracking-wide uppercase">Inschrijven</h4>
          <p class="text-sm text-slate-500 font-sans font-medium">Meld je team aan</p>
        </a>
        
        <a href="/spelregels" class="glass-card rounded-[2rem] p-8 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group border-slate-50">
          <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h4 class="text-xl font-bold text-slate-900 mb-2 font-condensed tracking-wide uppercase">Spelregels</h4>
          <p class="text-sm text-slate-500 font-sans font-medium">Hoe we spelen</p>
        </a>
        
        <a href="/contact" class="glass-card rounded-[2rem] p-8 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group border-slate-50">
          <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h4 class="text-xl font-bold text-slate-900 mb-2 font-condensed tracking-wide uppercase">Contact</h4>
          <p class="text-sm text-slate-500 font-sans font-medium">Stel je vraag</p>
        </a>
        
        <a href="/faq" class="glass-card rounded-[2rem] p-8 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group border-slate-50">
          <div class="w-12 h-12 bg-accent-100 text-accent-600 rounded-xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
          </div>
          <h4 class="text-xl font-bold text-slate-900 mb-2 font-condensed tracking-wide uppercase">FAQ</h4>
          <p class="text-sm text-slate-500 font-sans font-medium">Veelgestelde vragen</p>
        </a>
      </div>
    </div>
  </section>
  
  <Footer org={site.default.org} contact={site.default.contact} />
</Base>
