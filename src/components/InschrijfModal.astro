---
// InschrijfModal component - Modal met inschrijfformulier voor team en instuif
---

<!-- Modal overlay en container -->
<div 
  id="inschrijf-modal" 
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div 
    id="modal-backdrop"
    class="fixed inset-0 bg-slate-900/60 backdrop-blur-md transition-opacity duration-500 opacity-0"
    aria-hidden="true"
  ></div>
  
  <!-- Modal content -->
  <div class="relative z-10 w-full max-w-4xl max-h-[90vh] bg-white rounded-[2.5rem] shadow-2xl overflow-hidden transform transition-all duration-500 scale-90 opacity-0 border border-white/20" id="modal-content">
    
    <!-- Header -->
    <div class="sticky top-0 bg-white/80 backdrop-blur-lg border-b border-slate-100 px-6 sm:px-10 py-5 sm:py-6 flex items-center justify-between z-20">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-primary-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h2 id="modal-title" class="text-2xl sm:text-3xl text-slate-900 leading-none">
          Inschrijven
        </h2>
      </div>
      <button 
        id="modal-close-btn"
        type="button"
        class="p-2 rounded-xl hover:bg-slate-100 transition-all text-slate-400 hover:text-slate-900 hover:rotate-90"
        aria-label="Sluit modal"
      >
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- Scrollable content -->
    <div class="overflow-y-auto max-h-[calc(90vh-90px)] px-6 sm:px-10 py-8 sm:py-10 bg-dot-pattern text-slate-100 opacity-100">
      <div class="relative z-10">
        <!-- Informatie blok -->
        <div class="bg-gradient-to-br from-primary-600 to-accent-600 rounded-3xl p-6 sm:p-8 shadow-xl mb-10 text-white relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-16 -mt-16 group-hover:scale-110 transition-transform"></div>
          <div class="flex items-start gap-4 sm:gap-6 relative">
            <div class="bg-white/20 backdrop-blur-sm p-3 rounded-2xl">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            </div>
            <div>
              <h3 class="text-xl sm:text-2xl font-condensed font-bold mb-2 tracking-wide uppercase">Belangrijke informatie</h3>
              <p class="text-base sm:text-lg text-white/90 leading-relaxed font-sans font-medium">
                Reserveer alvast <span class="font-bold text-white underline decoration-white/30 underline-offset-4">woensdag 25 februari 2026</span> voor de Apenkooi Toernooi 2026 in uw agenda. 
                Hiervoor kan je vanaf 1 november opgeven via dit formulier.
              </p>
            </div>
          </div>
        </div>
        
        <!-- Team Inschrijfformulier -->
        <form 
          method="post" 
          action="/api/submit" 
          id="inschrijf-form-team"
          class="space-y-10"
        >
          <input type="hidden" name="formId" value="team" />
          
          <div class="grid sm:grid-cols-2 gap-8">
            <!-- Teamnaam -->
            <div class="sm:col-span-2">
              <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Naam van het team *</label>
              <p class="text-sm text-slate-500 mb-4 font-sans font-medium">Bedenk hier een leuke teamnaam zoals Brulapen, Slingerapen of the Monkeys.</p>
              <input 
                name="teamnaam" 
                placeholder="Hoe heet jullie team?" 
                required 
                class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-bold text-lg" 
              />
            </div>
            
            <!-- Contactpersoon -->
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Contactpersoon *</label>
              <p class="text-xs text-slate-500 mb-4 font-sans font-medium">Iemand van 16 jaar of ouder (begeleider).</p>
              <input 
                name="contactpersoon" 
                placeholder="Naam begeleider" 
                required 
                class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" 
              />
            </div>
            
            <!-- E-mail -->
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">E-mailadres *</label>
              <p class="text-xs text-slate-500 mb-4 font-sans font-medium">Voor de bevestiging en het schema.</p>
              <input 
                name="email" 
                type="email" 
                placeholder="jouw@email.nl" 
                required 
                class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" 
              />
            </div>
            
            <!-- Telefoon -->
            <div class="sm:col-span-2">
              <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Telefoonnummer *</label>
              <p class="text-xs text-slate-500 mb-4 font-sans font-medium">Voor de groepsapp met de laatste informatie.</p>
              <input 
                name="telefoon" 
                type="tel" 
                placeholder="06 12345678" 
                required
                minlength="6"
                class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" 
              />
            </div>
          </div>
          
          <!-- Aanmelding type -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-4 uppercase tracking-wider">Leeftijdscategorie *</label>
            <div class="grid sm:grid-cols-2 gap-4">
              <label class="flex items-center p-5 border-2 border-slate-100 rounded-2xl hover:bg-primary-50 hover:border-primary-200 cursor-pointer transition-all group has-[:checked]:bg-primary-50 has-[:checked]:border-primary-500">
                <input 
                  type="radio" 
                  name="aanmelding_type" 
                  value="Apenkooitoernooi categorie 1: Groep 4, 5, 6" 
                  required 
                  class="w-5 h-5 text-primary-600 focus:ring-primary-500 border-slate-300 transition-transform group-hover:scale-110" 
                />
                <div class="ml-4">
                  <span class="block text-lg font-bold text-slate-900 leading-none mb-1">Categorie 1</span>
                  <span class="block text-sm text-slate-500 font-sans font-medium">Groep 4, 5, 6</span>
                </div>
              </label>
              <label class="flex items-center p-5 border-2 border-slate-100 rounded-2xl hover:bg-primary-50 hover:border-primary-200 cursor-pointer transition-all group has-[:checked]:bg-primary-50 has-[:checked]:border-primary-500">
                <input 
                  type="radio" 
                  name="aanmelding_type" 
                  value="Apenkooitoernooi categorie 2: Groep 6, 7, 8" 
                  required 
                  class="w-5 h-5 text-primary-600 focus:ring-primary-500 border-slate-300 transition-transform group-hover:scale-110" 
                />
                <div class="ml-4">
                  <span class="block text-lg font-bold text-slate-900 leading-none mb-1">Categorie 2</span>
                  <span class="block text-sm text-slate-500 font-sans font-medium">Groep 6, 7, 8</span>
                </div>
              </label>
            </div>
          </div>
          
          <!-- Teamspelers -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Teamspelers *</label>
            <p class="text-sm text-slate-500 mb-6 font-sans font-medium leading-relaxed">
              Vul hier minimaal 6 namen in. Maximaal 10 spelers per team (6 spelers per ronde + wissels).
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {Array.from({ length: 10 }).map((_, i) => (
                <div class="relative group">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 font-bold font-condensed group-focus-within:text-primary-400 transition-colors">{i + 1}</span>
                  <input 
                    type="text"
                    name={`speler${i + 1}`} 
                    placeholder={i < 6 ? "Naam speler *" : "Naam speler (optioneel)"} 
                    required={i < 6} 
                    minlength="2"
                    class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" 
                  />
                </div>
              ))}
            </div>
          </div>
          
          <!-- Opmerkingen -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Opmerkingen</label>
            <textarea 
              name="opmerkingen" 
              placeholder="Zijn er nog dingen die we moeten weten?" 
              rows="3"
              class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none resize-none font-sans font-medium" 
            ></textarea>
          </div>
          
          <!-- Voorwaarden -->
          <div class="bg-amber-50 border border-amber-100 rounded-2xl p-6 shadow-sm">
            <p class="text-sm text-amber-900 font-sans font-medium leading-relaxed">
              Door te versturen ga je akkoord met de <a href="/voorwaarden" class="font-bold underline decoration-amber-300 hover:decoration-amber-600" target="_blank">voorwaarden</a> en <a href="/spelregels" class="font-bold underline decoration-amber-300 hover:decoration-amber-600" target="_blank">spelregels</a>.
            </p>
          </div>
          
          <input type="text" name="company" class="hidden" tabindex="-1" autocomplete="off" />
          <div id="modal-turnstile-container-team" class="flex justify-center min-h-[65px]"></div>
          <div id="modal-form-error-team" class="hidden bg-red-50 border border-red-200 rounded-2xl p-5 text-red-800 text-sm font-sans font-medium animate-fade-in"></div>
          
          <button 
            type="submit" 
            id="modal-submit-btn-team"
            class="btn-primary w-full !rounded-2xl group"
          >
            <span class="group-hover:translate-x-1 transition-transform flex items-center justify-center">
              Team inschrijven
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12h14m-7-7 7 7-7 7"/></svg>
            </span>
          </button>
        </form>

        <!-- Instuif Inschrijfformulier (Verborgen voor nu, zelfde stijl als hierboven) -->
        <form 
          method="post" 
          action="/api/submit" 
          id="inschrijf-form-instuif"
          class="space-y-10 hidden"
        >
          <input type="hidden" name="formId" value="instuif" />
          
          <div class="grid sm:grid-cols-2 gap-8">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Voornaam *</label>
              <input name="voornaam" placeholder="Voornaam" required minlength="2" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" />
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Achternaam *</label>
              <input name="achternaam" placeholder="Achternaam" required minlength="2" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" />
            </div>
            <div class="sm:col-span-2">
              <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">E-mailadres *</label>
              <input name="email" type="email" placeholder="jouw@email.nl" required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none font-sans font-medium" />
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-4 uppercase tracking-wider">Leeftijdsgroep *</label>
            <div class="grid sm:grid-cols-3 gap-4">
              {['4-5', '6', '7-8'].map(groep => (
                <label class="flex items-center p-4 border-2 border-slate-100 rounded-2xl hover:bg-primary-50 cursor-pointer transition-all has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                  <input type="radio" name="leeftijdsgroep" value={groep} required class="w-5 h-5 text-primary-600 focus:ring-primary-500" />
                  <span class="ml-3 font-bold text-slate-900">Groep {groep}</span>
                </label>
              ))}
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Medische informatie</label>
            <textarea name="medisch" placeholder="Eventuele allergieën of bijzonderheden..." rows="3" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary-100 focus:border-primary-500 focus:bg-white transition-all outline-none resize-none font-sans font-medium"></textarea>
          </div>

          <div class="bg-amber-50 border border-amber-100 rounded-2xl p-6">
            <p class="text-sm text-amber-900 font-sans font-medium">Door te versturen ga je akkoord met de voorwaarden en spelregels.</p>
          </div>
          
          <input type="text" name="company" class="hidden" tabindex="-1" autocomplete="off" />
          <div id="modal-turnstile-container-instuif" class="flex justify-center min-h-[65px]"></div>
          <div id="modal-form-error-instuif" class="hidden bg-red-50 border border-red-200 rounded-2xl p-5 text-red-800 text-sm animate-fade-in"></div>
          
          <button type="submit" id="modal-submit-btn-instuif" class="btn-primary w-full !rounded-2xl group">
             <span class="group-hover:translate-x-1 transition-transform flex items-center justify-center">
              Inschrijving afronden
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12h14m-7-7 7 7-7 7"/></svg>
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Laad Turnstile script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  (function() {
    const modal = document.getElementById('inschrijf-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const closeBtn = document.getElementById('modal-close-btn');
    const modalContent = document.getElementById('modal-content');
    const formTeam = document.getElementById('inschrijf-form-team');
    const formInstuif = document.getElementById('inschrijf-form-instuif');
    const containerTeam = document.getElementById('modal-turnstile-container-team');
    const containerInstuif = document.getElementById('modal-turnstile-container-instuif');
    
    let currentFormType = 'team';
    let widgetLoadedTeam = false;
    let widgetLoadedInstuif = false;
    let widgetIdTeam = null;
    let widgetIdInstuif = null;
    
    function toggleRequiredAttributes(form, enable) {
      if (!form) return;
      const requiredFields = form.querySelectorAll('[required]');
      requiredFields.forEach(field => {
        if (enable) field.setAttribute('required', '');
        else field.removeAttribute('required');
      });
    }
    
    function setFormType(type) {
      if (type === currentFormType) return;
      currentFormType = type;
      
      if (type === 'team') {
        formTeam?.classList.remove('hidden');
        toggleRequiredAttributes(formTeam, true);
        formInstuif?.classList.add('hidden');
        toggleRequiredAttributes(formInstuif, false);
        resetTurnstile('instuif');
        if (!widgetLoadedTeam && containerTeam) loadTurnstile('team');
      } else {
        formInstuif?.classList.remove('hidden');
        toggleRequiredAttributes(formInstuif, true);
        formTeam?.classList.add('hidden');
        toggleRequiredAttributes(formTeam, false);
        resetTurnstile('team');
        if (!widgetLoadedInstuif && containerInstuif) loadTurnstile('instuif');
      }
    }
    
    function openModal(formType = 'team') {
      if (!modal || !backdrop || !modalContent) return;
      setFormType(formType);
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      requestAnimationFrame(() => {
        backdrop.classList.remove('opacity-0');
        backdrop.classList.add('opacity-100');
        modalContent.classList.remove('scale-90', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      });
      
      if (!widgetLoadedTeam && formType === 'team') loadTurnstile('team');
      if (!widgetLoadedInstuif && formType === 'instuif') loadTurnstile('instuif');
    }
    
    function closeModal() {
      if (!modal || !backdrop || !modalContent) return;
      
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      modalContent.classList.remove('scale-100', 'opacity-100');
      modalContent.classList.add('scale-90', 'opacity-0');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
        (formTeam as HTMLFormElement)?.reset();
        (formInstuif as HTMLFormElement)?.reset();
        resetTurnstile('team');
        resetTurnstile('instuif');
      }, 500);
    }
    
    function resetTurnstile(type) {
      const widgetId = type === 'team' ? widgetIdTeam : widgetIdInstuif;
      const container = type === 'team' ? containerTeam : containerInstuif;
      if (widgetId !== null && (window as any).turnstile) {
        try { (window as any).turnstile.remove(widgetId); } catch(e){}
      }
      if (type === 'team') { widgetIdTeam = null; widgetLoadedTeam = false; }
      else { widgetIdInstuif = null; widgetLoadedInstuif = false; }
      if (container) container.innerHTML = '';
    }
    
    async function loadTurnstile(type) {
      const container = type === 'team' ? containerTeam : containerInstuif;
      if (!container || (type === 'team' ? widgetLoadedTeam : widgetLoadedInstuif)) return;

      try {
        const response = await fetch('/api/turnstile-key');
        const data = await response.json();

        if (data.siteKey) {
          // Wacht tot Turnstile script geladen is (max 3 seconden)
          if (typeof (window as any).turnstile === 'undefined') {
            await new Promise<void>((resolve, reject) => {
              let attempts = 0;
              const i = setInterval(() => {
                attempts++;
                if (typeof (window as any).turnstile !== 'undefined') {
                  clearInterval(i);
                  resolve();
                } else if (attempts >= 30) {
                  clearInterval(i);
                  reject(new Error('Turnstile script niet geladen na 3 seconden'));
                }
              }, 100);
            });
          }

          if ((window as any).turnstile && container.children.length === 0) {
            const widgetDiv = document.createElement('div');
            container.appendChild(widgetDiv);
            try {
              const currentHost = window.location.hostname;
              const wId = (window as any).turnstile.render(widgetDiv, {
                sitekey: data.siteKey,
                theme: 'light',
                callback: () => {},
                'error-callback': (error: any) => {
                  container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium"><p class="font-bold mb-1">⚠️ Domein niet toegestaan</p><p>Het domein <code class="bg-red-100 px-1 rounded">' + currentHost + '</code> is niet toegevoegd aan de Turnstile-domeinen.</p></div>';
                },
                'expired-callback': () => {
                  const widgetId = type === 'team' ? widgetIdTeam : widgetIdInstuif;
                  if (widgetId !== null && (window as any).turnstile) {
                    try { (window as any).turnstile.reset(widgetId); } catch(e) {}
                  }
                }
              });
              if (type === 'team') { widgetIdTeam = wId; widgetLoadedTeam = true; }
              else { widgetIdInstuif = wId; widgetLoadedInstuif = true; }
            } catch (renderError) {
              container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium">⚠️ Captcha kon niet worden geladen.</div>';
            }
          }
        } else {
          container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium">⚠️ Captcha niet beschikbaar: PUBLIC_TURNSTILE_SITE_KEY niet ingesteld.</div>';
        }
      } catch (err) {
        container.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-red-800 text-sm text-center font-sans font-medium">⚠️ Captcha kon niet worden geladen.</div>';
      }
    }
    
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    
    function setupForm(form, type) {
      if (!form) return;
      const errorDiv = document.getElementById(`modal-form-error-${type}`);
      const submitBtn = document.getElementById(`modal-submit-btn-${type}`);
      
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (errorDiv) { errorDiv.classList.add('hidden'); errorDiv.textContent = ''; }
        
        const token = (form.querySelector('input[name="cf-turnstile-response"]') as HTMLInputElement)?.value;
        if (!token) {
          if (errorDiv) { errorDiv.textContent = 'Captcha verplicht.'; errorDiv.classList.remove('hidden'); }
          return;
        }
        
        if (submitBtn) {
          submitBtn.disabled = true;
          const oldText = submitBtn.innerHTML;
          submitBtn.innerHTML = 'Verzenden...';
          
          try {
            const res = await fetch('/api/submit', { method: 'POST', body: new FormData(form) });
            if (res.ok) { closeModal(); window.location.href = '/bedankt'; }
            else {
              const err = await res.json();
              if (errorDiv) { errorDiv.textContent = err.error || 'Fout bij verzenden.'; errorDiv.classList.remove('hidden'); }
            }
          } catch(e) {
            if (errorDiv) { errorDiv.textContent = 'Netwerkfout.'; errorDiv.classList.remove('hidden'); }
          } finally {
            if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = oldText; }
          }
        }
      });
    }
    
    setupForm(formTeam, 'team');
    setupForm(formInstuif, 'instuif');
    (window as any).openInschrijfModal = openModal;
  })();
</script>

<style>
  #inschrijf-modal { z-index: 9999; }
</style>
