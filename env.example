# Cloudflare Turnstile (aanbevolen - geen Google account nodig)
# PUBLIC_ prefix is nodig voor frontend variabelen in Astro
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
PUBLIC_SENTRY_DSN=your_sentry_dsn
TURNSTILE_SECRET=your_turnstile_secret

# Sentry (voor source map uploads bij builds - optioneel)
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# FreeScout API (voor email verzending)
FREESCOUT_API_URL=https://your-freescout-instance.com
FREESCOUT_API_KEY=your_freescout_api_key
FREESCOUT_MAILBOX_ID=1
